{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Music Video Studio",
  "version": "0.6.3",
  "identifier": "studio.lightkid.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "AI Music Video Studio",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
    "bundle": {
    "active": true,
    "targets": "all",
      "externalBin": [
        "binaries/mongod"
      ],
      "resources": [
        "../midjourney-proxy/scripts",
        "../src-tauri/packaging"
      ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "ffmpeg"
        ]
      }
    }
  }
}
